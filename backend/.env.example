NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
MONGO_URI=mongodb://localhost:27017/uni-mate

JWT_ACCESS_SECRET=dev_access_secret_unimate_123456
JWT_REFRESH_SECRET=dev_refresh_secret_unimate_123456
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d
COOKIE_SECURE=false

# EMAIL OTP - Gmail SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
