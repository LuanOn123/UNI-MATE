# OTP CONFIG
OTP_EXPIRES_MINUTES=5
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5
OTP_MAX_SEND_PER_HOUR=5
DEV_PRINT_OTP=true

GOOGLE_MAPS_API_KEY=
OSRM_BASE_URL=https://router.project-osrm.org
OSRM_PROFILE=driving
DISTANCE_R_PREFILTER_METERS=10000
DISTANCE_T50_MINUTES=15
DISTANCE_TMAX_MINUTES=45
DISTANCE_CANDIDATE_LIMIT=50
